# ── Identity ────────────────────────────────────────────────────────────────
USER_ID=steven
USER_TIMEZONE=America/Toronto

# ── AI (at least one recommended; app degrades gracefully without) ──────────
ANTHROPIC_API_KEY=            # console.anthropic.com — classifier, Jarvis, finance, nutrition
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=               # platform.openai.com — Whisper transcription, embeddings, fallback classifier
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# ── Database (omit both to use the zero-setup local JSON store) ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth gate (omit to leave the dashboard open for local dev) ──────────────
AUTH_SECRET=                  # openssl rand -hex 32
DASHBOARD_PASSWORD=
API_SECRET=                   # openssl rand -hex 16 — x-api-secret header for scripts

# ── Calendar (read) ──────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ICAL_URL=     # Google Calendar → Settings → "Secret address in iCal format"

# ── Meeting booking (write — "book a meeting with John tomorrow at 3") ───────
# OAuth client from console.cloud.google.com with the Calendar API enabled;
# mint the refresh token once with: node scripts/google-refresh-token.mjs
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_BOOKING_CALENDAR_ID=   # optional; defaults to "primary"
# Address book for spoken names → invite emails. Format: Name <email>; Name <email>
MEETING_CONTACTS=             # e.g. John Smith <john@acme.com>; Jane Doe <jane@x.io>
